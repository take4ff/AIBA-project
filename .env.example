# Supabase 接続情報（未設定の場合は backend/output/ へローカル出力）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key

# GitHub Personal Access Token（Search APIのレート制限緩和用・任意）
GITHUB_TOKEN=ghp_xxx

# EPO Open Patent Services の認証情報（特許センチメント用・任意）
# 無料登録で consumer key/secret を取得（米国SSN等の本人確認は不要・日本から可）。
# https://developers.epo.org/ 。未設定なら特許指標はスキップ。
EPO_OPS_KEY=your-ops-consumer-key
EPO_OPS_SECRET=your-ops-consumer-secret

# FRED（St. Louis Fed）APIキー（半導体出荷量など月次マクロデータ用・任意）
# 無料取得: https://fredaccount.stlouisfed.org/apikeys
# 未設定なら FRED 信号はスキップ（他の指標には影響なし）。
FRED_API_KEY=your-fred-api-key
