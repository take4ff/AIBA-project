# Supabase 接続情報（未設定の場合は backend/output/ へローカル出力）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key

# GitHub Personal Access Token（Search APIのレート制限緩和用・任意）
GITHUB_TOKEN=ghp_xxx

# USPTO Open Data Portal API キー（特許センチメント用・任意）
# PatentsView は 2026-03 に ODP(api.uspto.gov) へ移行。USPTO.gov＋ID.me 連携で取得。
# https://data.uspto.gov/apis/getting-started 。未設定なら特許指標はスキップ。
USPTO_ODP_API_KEY=your-uspto-odp-key
