# Supabase 接続情報（未設定の場合は backend/output/ へローカル出力）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key

# GitHub Personal Access Token（Search APIのレート制限緩和用・任意）
GITHUB_TOKEN=ghp_xxx

# PatentsView Search API キー（特許センチメント用・任意）
# 無料で取得: https://patentsview.org/apis/keyrequest 。未設定なら特許指標はスキップ。
PATENTSVIEW_API_KEY=your-patentsview-key
