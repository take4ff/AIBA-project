# フロントエンドは読み取り専用。publishable(anon)キーを使う。
# service_role キーは絶対にここへ置かないこと（ブラウザに露出します）。
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# オンデマンド再検証（/api/revalidate）用の共有シークレット。
# 任意の長いランダム文字列を設定し、GitHub Actions の Secrets（REVALIDATE_TOKEN）にも同じ値を登録する。
REVALIDATE_TOKEN=
